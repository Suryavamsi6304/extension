# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# AI provider selection: groq | gemini | pluralsight
AI_PROVIDER=groq

# Groq (REQUIRED — the default provider)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (optional — only needed when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Pluralsight Prompt Sandbox (optional — only needed when AI_PROVIDER=pluralsight)
PLURALSIGHT_API_KEY=your_pluralsight_api_key_here
PLURALSIGHT_MODEL=chatgpt-4o

# Server config
BACKEND_PORT=8765
MAX_FILE_SIZE_KB=500
LLM_CACHE_TTL=300
