{
  "name": "genai-project-insights",
  "displayName": "GenAI Project Insights",
  "description": "AI-powered project analysis for developers. Scan & summarize your codebase, explain code, chat with your project, track git activity, and find TODOs — powered by Pluralsight, OpenAI, Anthropic, Gemini, or Ollama.",
  "version": "1.0.0",
  "publisher": "genai-insights",
  "author": {
    "name": "GenAI Insights"
  },
  "license": "MIT",
  "homepage": "https://github.com/genai-insights/genai-project-insights",
  "repository": {
    "type": "git",
    "url": "https://github.com/genai-insights/genai-project-insights.git"
  },
  "bugs": {
    "url": "https://github.com/genai-insights/genai-project-insights/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "genai",
    "project analysis",
    "code explanation",
    "code chat",
    "git insights",
    "todo scanner",
    "pluralsight",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "productivity",
    "developer tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "genai.scanProject",
        "title": "GenAI: Scan & Summarize Project",
        "icon": "$(search)"
      },
      {
        "command": "genai.explainCode",
        "title": "GenAI: Explain Selected Code",
        "icon": "$(lightbulb)"
      },
      {
        "command": "genai.openChat",
        "title": "GenAI: Open Project Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "genai.gitInsights",
        "title": "GenAI: Show Git Insights",
        "icon": "$(git-commit)"
      },
      {
        "command": "genai.findTodos",
        "title": "GenAI: Find & List TODOs",
        "icon": "$(checklist)"
      },
      {
        "command": "genai.pickProvider",
        "title": "GenAI: Switch AI Provider",
        "icon": "$(settings-gear)"
      },
      {
        "command": "genai.startBackend",
        "title": "GenAI: Start Backend Server",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "genai.explainCode",
          "when": "editorHasSelection",
          "group": "genai@1"
        }
      ],
      "commandPalette": [
        {
          "command": "genai.explainCode",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "genai-sidebar",
          "title": "GenAI Insights",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "genai-sidebar": [
        {
          "id": "genai.activityView",
          "name": "File Activity",
          "icon": "$(pulse)"
        },
        {
          "id": "genai.todoView",
          "name": "TODOs & FIXMEs",
          "icon": "$(checklist)"
        }
      ]
    },
    "configuration": {
      "title": "GenAI Project Insights",
      "properties": {
        "genai.provider": {
          "type": "string",
          "enum": ["groq", "gemini", "pluralsight", "anthropic", "openai", "ollama"],
          "enumDescriptions": [
            "Groq — fast inference (llama-3.3-70b), requires API key from console.groq.com",
            "Google Gemini — requires API key from aistudio.google.com",
            "Pluralsight Prompt Sandbox (recommended for corporate environments)",
            "Anthropic Claude — requires API key from console.anthropic.com",
            "OpenAI GPT-4o — requires API key from platform.openai.com",
            "Ollama — local models, no API key needed"
          ],
          "default": "groq",
          "description": "AI provider to use for all analysis features"
        },
        "genai.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key. Get one at console.groq.com"
        },
        "genai.pluralsightApiKey": {
          "type": "string",
          "default": "",
          "description": "Pluralsight Prompt Sandbox API key",
          "markdownDescription": "Pluralsight Prompt Sandbox API key. Obtain from your Pluralsight lab environment."
        },
        "genai.pluralsightModel": {
          "type": "string",
          "enum": ["chatgpt-4o", "claude-instant-v1", "claude-v2", "titan-tg1-large", "jamba-mini", "jamba-large", "llama2-13b"],
          "default": "chatgpt-4o",
          "description": "Pluralsight model to use"
        },
        "genai.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (Claude models)",
          "markdownDescription": "Anthropic API key. Get one at [console.anthropic.com](https://console.anthropic.com)"
        },
        "genai.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (GPT models)",
          "markdownDescription": "OpenAI API key. Get one at [platform.openai.com](https://platform.openai.com)"
        },
        "genai.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Google Gemini API key",
          "markdownDescription": "Google Gemini API key. Get one at [aistudio.google.com](https://aistudio.google.com)"
        },
        "genai.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL (for local models)"
        },
        "genai.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "Ollama model name (e.g. llama3, mistral, codellama)"
        },
        "genai.backendPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the Python backend server"
        },
        "genai.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Python backend when VS Code opens"
        },
        "genai.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to Python interpreter. Leave empty to auto-detect (recommended)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
