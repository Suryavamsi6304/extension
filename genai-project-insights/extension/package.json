{
  "name": "genai-project-insights",
  "displayName": "GenAI Project Insights",
  "description": "AI-powered project analysis for developers. Scan & summarize your codebase, explain code, chat with your project, track git activity, and find TODOs — powered by Groq, Gemini, or Pluralsight.",
  "version": "1.0.0",
  "publisher": "SURYAVAMSI",
  "author": {
    "name": "GenAI Insights"
  },
  "license": "MIT",
  "homepage": "https://github.com/genai-insights/genai-project-insights",
  "repository": {
    "type": "git",
    "url": "https://github.com/genai-insights/genai-project-insights.git"
  },
  "bugs": {
    "url": "https://github.com/genai-insights/genai-project-insights/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "genai",
    "project analysis",
    "code explanation",
    "code chat",
    "git insights",
    "todo scanner",
    "pluralsight",
    "gemini",
    "productivity",
    "developer tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "genai.scanProject",
        "title": "GenAI: Scan & Summarize Project",
        "icon": "$(search)"
      },
      {
        "command": "genai.explainCode",
        "title": "GenAI: Explain Selected Code",
        "icon": "$(lightbulb)"
      },
      {
        "command": "genai.openChat",
        "title": "GenAI: Open Project Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "genai.gitInsights",
        "title": "GenAI: Show Git Insights",
        "icon": "$(git-commit)"
      },
      {
        "command": "genai.findTodos",
        "title": "GenAI: Find & List TODOs",
        "icon": "$(checklist)"
      },
      {
        "command": "genai.pickProvider",
        "title": "GenAI: Switch AI Provider",
        "icon": "$(settings-gear)"
      },
      {
        "command": "genai.startBackend",
        "title": "GenAI: Start Backend Server",
        "icon": "$(play)"
      },
      {
        "command": "genai.setApiKey",
        "title": "GenAI: Set / Rotate API Key",
        "icon": "$(key)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "genai.explainCode",
          "when": "editorHasSelection",
          "group": "genai@1"
        }
      ],
      "commandPalette": [
        {
          "command": "genai.explainCode",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "genai-sidebar",
          "title": "GenAI Insights",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "genai-sidebar": [
        {
          "id": "genai.activityView",
          "name": "File Activity",
          "icon": "$(pulse)"
        },
        {
          "id": "genai.todoView",
          "name": "TODOs & FIXMEs",
          "icon": "$(checklist)"
        }
      ]
    },
    "configuration": {
      "title": "GenAI Project Insights",
      "properties": {
        "genai.provider": {
          "type": "string",
          "enum": [
            "groq",
            "gemini",
            "pluralsight"
          ],
          "enumDescriptions": [
            "Groq — fast inference (llama-3.3-70b), requires API key from console.groq.com",
            "Google Gemini — requires API key from aistudio.google.com",
            "Pluralsight Prompt Sandbox (recommended for corporate environments)"
          ],
          "default": "groq",
          "description": "AI provider to use for all analysis features"
        },
        "genai.pluralsightModel": {
          "type": "string",
          "enum": [
            "chatgpt-4o",
            "claude-instant-v1",
            "claude-v2",
            "titan-tg1-large",
            "jamba-mini",
            "jamba-large",
            "llama2-13b"
          ],
          "default": "chatgpt-4o",
          "description": "Pluralsight model to use"
        },
        "genai.backendPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the Python backend server"
        },
        "genai.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Python backend when VS Code opens"
        },
        "genai.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to Python interpreter. Leave empty to auto-detect (recommended)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run esbuild -- --production",
    "compile": "tsc -p ./",
    "esbuild": "node esbuild.mjs",
    "esbuild:watch": "node esbuild.mjs --watch",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^2.15.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "overrides": {
    "undici": "^6.21.1"
  }
}
